generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  avatar        String?
  passwordHash  String?  // null for OAuth-only users
  profession    String?
  timezone      String   @default("Europe/Paris")
  assistantName String   @default("Burofree AI")
  assistantTone String   @default("friendly")
  theme         String   @default("dark")
  focusMode     Boolean  @default(false)
  onboardingDone       Boolean  @default(false)
  hourlyRate            Float?
  weeklyTargetHours     Float?
  weeklyTargetRevenue   Float?
  maxDailyHours         Float?
  stripeAccountId       String?
  stripeCustomerId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tasks         Task[]
  events        CalendarEvent[]
  reminders     Reminder[]
  emailAccounts EmailAccount[]
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  invoices      Invoice[]
  timeEntries   TimeEntry[]
  documents     Document[]
  snippets      Snippet[]
  notifications     Notification[]
  goals             WeeklyGoal[]
  chatMessages      ChatMessage[]
  pushSubscriptions PushSubscription[]
  meetings          Meeting[]
  contracts         Contract[]
  templates         Template[]
  automationPrefs   AutomationPreference[]
  automationLogs    AutomationLog[]
  tags              Tag[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  clientName  String?
  color       String   @default("#10b981")
  status      String   @default("active")
  budget      Float?
  deadline    DateTime?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  invoices    Invoice[]
  documents   Document[]
  timeEntries TimeEntry[]
  meetings    Meeting[]
  contracts   Contract[]
  tags        ProjectTag[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id            String    @id @default(cuid())
  title         String
  description   String?
  status        String    @default("todo")
  priority      String    @default("medium")
  dueDate       DateTime?
  reminderAt    DateTime?
  completedAt   DateTime?
  category      String?
  estimatedTime Int?
  actualTime    Int?
  recurrence    String?
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeEntries   TimeEntry[]
  tags          TaskTag[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  color       String    @default("#10b981")
  allDay      Boolean   @default(false)
  location    String?
  type        String    @default("meeting")
  source      String    @default("local")
  sourceId    String?   @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Reminder {
  id          String   @id @default(cuid())
  title       String
  message     String?
  remindAt    DateTime
  isSent      Boolean  @default(false)
  type        String   @default("in_app")
  relatedId   String?
  relatedType String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailAccount {
  id              String    @id @default(cuid())
  provider        String
  email           String
  accessToken     String?
  refreshToken    String?
  tokenExpiry     DateTime?
  scopes          String?
  imapHost        String?
  imapPort        Int?
  smtpHost        String?
  smtpPort        Int?
  isPrimary       Boolean   @default(false)
  gmailHistoryId  String?
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails          Email[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Email {
  id             String      @id @default(cuid())
  fromAddress    String
  fromName       String?
  toAddress      String
  subject        String
  body           String?
  snippet        String?
  isRead         Boolean     @default(false)
  isStarred      Boolean     @default(false)
  isSent         Boolean     @default(false)
  category       String      @default("client")
  hasTask        Boolean     @default(false)
  scheduledAt    DateTime?
  source         String      @default("local")
  sourceId       String?     @unique
  emailAccountId String
  emailAccount   EmailAccount @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)
  userId         String
  tags           EmailTag[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Invoice {
  id                     String    @id @default(cuid())
  number                 String
  type                   String    @default("invoice")
  clientName             String
  clientEmail            String?
  clientAddress          String?
  items                  String
  subtotal               Float
  taxRate                Float     @default(20.0)
  taxAmount              Float
  total                  Float
  currency               String    @default("EUR")
  status                 String    @default("draft")
  dueDate                DateTime?
  paidAt                 DateTime?
  notes                  String?
  stripePaymentIntentId  String?
  stripeCheckoutUrl      String?
  paymentMethod          String    @default("manual")
  projectId              String?
  project                Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId                 String
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model TimeEntry {
  id          String   @id @default(cuid())
  startTime   DateTime
  endTime     DateTime?
  duration    Int?
  description String?
  isBillable  Boolean  @default(true)
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Document {
  id        String   @id @default(cuid())
  name      String
  type      String
  content   String?
  fileUrl   String?
  mimeType  String?
  size      Int?
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags      DocumentTag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Snippet {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  channel   String   @default("in_app")
  isRead    Boolean  @default(false)
  actionUrl String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeeklyGoal {
  id        String   @id @default(cuid())
  title     String
  target    Int?
  current   Int      @default(0)
  unit      String   @default("tasks")
  weekStart DateTime
  weekEnd   DateTime
  completed Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Meeting {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  location    String?
  meetingUrl  String?    // Zoom, Google Meet, Teams link
  type        String     @default("video") // video, phone, in_person
  status      String     @default("scheduled") // scheduled, completed, cancelled
  agenda      String?    // Meeting agenda (markdown)
  notes       String?    // Meeting notes/minutes (markdown)
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Contract {
  id             String    @id @default(cuid())
  title          String
  description    String?
  type           String     @default("service") // service, nda, partnership, freelance
  status         String     @default("draft") // draft, sent, signed, active, expired, terminated
  clientName     String
  clientEmail    String?
  clientAddress  String?
  startDate      DateTime?
  endDate        DateTime?
  value          Float?     // Contract value
  currency       String     @default("EUR")
  terms          String?    // Contract terms (markdown)
  notes          String?
  fileUrl        String?    // Uploaded contract file
  projectId      String?
  project        Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

// ─── PRIORITÉ 2 — Productivité ───────────────────────────────────────────────────

/// Système de templates réutilisables avec variables dynamiques
model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // contract, quote, email, project_structure, client_response
  content     String   // Contenu avec variables {client_name}, {date}, etc.
  variables   String   @default("[]") // JSON array of variable names
  category    String   @default("general") // Catégorie pour le tri
  icon        String?  // Nom d'icône Lucide
  isDefault   Boolean  @default(false) // Template prédéfini
  usageCount  Int      @default(0)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Préférences utilisateur pour les rappels automatiques
model AutomationPreference {
  id        String   @id @default(cuid())
  type      String   // overdue_tasks, unpaid_invoices, meeting_reminder, email_followup
  enabled   Boolean  @default(true)
  channel   String   @default("in_app") // in_app, email, both
  frequency String   @default("15min") // 15min, 30min, 1h, daily
  threshold Int      @default(7) // Seuil en jours/minutes selon le type
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Journal des actions automatisées
model AutomationLog {
  id         String   @id @default(cuid())
  type       String   // overdue_tasks, unpaid_invoices, meeting_reminder, email_followup
  action     String   // notification_sent, email_sent, reminder_created
  details    String?  // JSON with context details
  relatedId  String?  // ID de l'entité concernée
  success    Boolean  @default(true)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

/// Tags multi-dimensionnels avec couleur et catégorie
model Tag {
  id          String   @id @default(cuid())
  name        String
  color       String   @default("#10b981")
  icon        String?  // Nom d'icône Lucide
  category    String   @default("general") // urgent, client, status, billing, custom
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskTags    TaskTag[]
  emailTags   EmailTag[]
  documentTags DocumentTag[]
  projectTags ProjectTag[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, name])
}

/// Junction table: Task ↔ Tag
model TaskTag {
  id      String @id @default(cuid())
  taskId  String
  tagId   String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([taskId, tagId])
}

/// Junction table: Email ↔ Tag
model EmailTag {
  id      String @id @default(cuid())
  emailId String
  tagId   String
  email   Email  @relation(fields: [emailId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([emailId, tagId])
}

/// Junction table: Document ↔ Tag
model DocumentTag {
  id         String   @id @default(cuid())
  documentId String
  tagId      String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([documentId, tagId])
}

/// Junction table: Project ↔ Tag
model ProjectTag {
  id        String  @id @default(cuid())
  projectId String
  tagId     String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([projectId, tagId])
}
