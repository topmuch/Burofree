generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../db/custom.db"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  avatar        String?
  passwordHash  String?  // null for OAuth-only users
  profession    String?
  timezone      String   @default("Europe/Paris")
  assistantName String   @default("Burozen AI")
  assistantTone String   @default("friendly")
  theme         String   @default("dark")
  focusMode     Boolean  @default(false)
  onboardingDone       Boolean  @default(false)
  hourlyRate            Float?
  weeklyTargetHours     Float?
  weeklyTargetRevenue   Float?
  maxDailyHours         Float?
  stripeAccountId       String?
  stripeCustomerId      String?
  role          String   @default("user") // user, admin, superadmin
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret String?  // TOTP secret (encrypted)
  suspendedAt    DateTime? // Null = active, set = suspended
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tasks         Task[]
  events        CalendarEvent[]
  reminders     Reminder[]
  emailAccounts EmailAccount[]
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  invoices      Invoice[]
  timeEntries   TimeEntry[]
  documents     Document[]
  snippets      Snippet[]
  notifications     Notification[]
  goals             WeeklyGoal[]
  chatMessages      ChatMessage[]
  pushSubscriptions PushSubscription[]
  meetings          Meeting[]
  contracts         Contract[]
  templates         Template[]
  automationPrefs   AutomationPreference[]
  automationLogs    AutomationLog[]
  tags              Tag[]
  modules           UserModule[]
  portalInvites     PortalInvite[]
  integrations      IntegrationConnection[]
  focusSessions     FocusSession[]
  voiceLogs         VoiceLog[]
  teamMemberships   TeamMember[]
  auditLogs         AuditLog[]
  exportJobs        ExportJob[]
  subscriptions     Subscription[]
  offlineActions    OfflineAction[]
  backupCodes       BackupCode[]
  consentLogs       ConsentLog[]
  gdprRequests      GdprRequest[]
  deletionSchedule  GdprDeletionSchedule[]
  dpoContacts       DpoContact[]
  contacts           Contact[]
  conversations      Conversation[]
  channelAccounts    ChannelAccount[]
  crmContacts        CrmContact[]
  pipelines          Pipeline[]
  deals              Deal[]      @relation("DealOwner")
  assignedDeals      Deal[]      @relation("DealAssignee")
  campaigns          Campaign[]
  workflows          Workflow[]
  emailTemplates     EmailTemplate[]
  workspaceMemberships WorkspaceMember[]
  metricSnapshots    MetricSnapshot[]
  merchants          Merchant[]
  paymentTransactionsAsAgent PaymentTransaction[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  clientName  String?
  color       String   @default("#10b981")
  status      String   @default("active")
  budget      Float?
  deadline    DateTime?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  invoices    Invoice[]
  documents   Document[]
  timeEntries TimeEntry[]
  meetings    Meeting[]
  contracts   Contract[]
  tags           ProjectTag[]
  portalInvites  PortalInvite[]
  focusSessions  FocusSession[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Task {
  id            String    @id @default(cuid())
  title         String
  description   String?
  status        String    @default("todo")
  priority      String    @default("medium")
  dueDate       DateTime?
  reminderAt    DateTime?
  completedAt   DateTime?
  category      String?
  estimatedTime Int?
  actualTime    Int?
  recurrence    String?
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeEntries   TimeEntry[]
  tags          TaskTag[]
  focusSessions FocusSession[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  color       String    @default("#10b981")
  allDay      Boolean   @default(false)
  location    String?
  type        String    @default("meeting")
  source      String    @default("local")
  sourceId    String?   @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Reminder {
  id          String   @id @default(cuid())
  title       String
  message     String?
  remindAt    DateTime
  isSent      Boolean  @default(false)
  type        String   @default("in_app")
  relatedId   String?
  relatedType String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailAccount {
  id              String    @id @default(cuid())
  provider        String
  email           String
  accessToken     String?
  refreshToken    String?
  tokenExpiry     DateTime?
  scopes          String?
  imapHost        String?
  imapPort        Int?
  smtpHost        String?
  smtpPort        Int?
  isPrimary       Boolean   @default(false)
  gmailHistoryId  String?
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails          Email[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Email {
  id             String      @id @default(cuid())
  fromAddress    String
  fromName       String?
  toAddress      String
  subject        String
  body           String?
  snippet        String?
  isRead         Boolean     @default(false)
  isStarred      Boolean     @default(false)
  isSent         Boolean     @default(false)
  category       String      @default("client")
  hasTask        Boolean     @default(false)
  scheduledAt    DateTime?
  source         String      @default("local")
  sourceId       String?     @unique
  emailAccountId String
  emailAccount   EmailAccount @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)
  userId         String
  tags           EmailTag[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Invoice {
  id                     String    @id @default(cuid())
  number                 String
  type                   String    @default("invoice")
  clientName             String
  clientEmail            String?
  clientAddress          String?
  items                  String
  subtotal               Float
  taxRate                Float     @default(20.0)
  taxAmount              Float
  total                  Float
  currency               String    @default("EUR")
  status                 String    @default("draft")
  dueDate                DateTime?
  paidAt                 DateTime?
  notes                  String?
  stripePaymentIntentId  String?
  stripeCheckoutUrl      String?
  paymentMethod          String    @default("manual")
  projectId              String?
  project                Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId                 String
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model TimeEntry {
  id          String   @id @default(cuid())
  startTime   DateTime
  endTime     DateTime?
  duration    Int?
  description String?
  isBillable  Boolean  @default(true)
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Document {
  id        String   @id @default(cuid())
  name      String
  type      String
  content   String?
  fileUrl   String?
  mimeType  String?
  size      Int?
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags      DocumentTag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Snippet {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  channel   String   @default("in_app")
  isRead    Boolean  @default(false)
  actionUrl String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeeklyGoal {
  id        String   @id @default(cuid())
  title     String
  target    Int?
  current   Int      @default(0)
  unit      String   @default("tasks")
  weekStart DateTime
  weekEnd   DateTime
  completed Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Meeting {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  location    String?
  meetingUrl  String?    // Zoom, Google Meet, Teams link
  type        String     @default("video") // video, phone, in_person
  status      String     @default("scheduled") // scheduled, completed, cancelled
  agenda      String?    // Meeting agenda (markdown)
  notes       String?    // Meeting notes/minutes (markdown)
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Contract {
  id             String    @id @default(cuid())
  title          String
  description    String?
  type           String     @default("service") // service, nda, partnership, freelance
  status         String     @default("draft") // draft, sent, signed, active, expired, terminated
  clientName     String
  clientEmail    String?
  clientAddress  String?
  startDate      DateTime?
  endDate        DateTime?
  value          Float?     // Contract value
  currency       String     @default("EUR")
  terms          String?    // Contract terms (markdown)
  notes          String?
  fileUrl        String?    // Uploaded contract file
  projectId      String?
  project        Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

// ─── PRIORITÉ 2 — Productivité ───────────────────────────────────────────────────

/// Système de templates réutilisables avec variables dynamiques
model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // contract, quote, email, project_structure, client_response
  content     String   // Contenu avec variables {client_name}, {date}, etc.
  variables   String   @default("[]") // JSON array of variable names
  category    String   @default("general") // Catégorie pour le tri
  icon        String?  // Nom d'icône Lucide
  isDefault   Boolean  @default(false) // Template prédéfini
  usageCount  Int      @default(0)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Préférences utilisateur pour les rappels automatiques
model AutomationPreference {
  id        String   @id @default(cuid())
  type      String   // overdue_tasks, unpaid_invoices, meeting_reminder, email_followup
  enabled   Boolean  @default(true)
  channel   String   @default("in_app") // in_app, email, both
  frequency String   @default("15min") // 15min, 30min, 1h, daily
  threshold Int      @default(7) // Seuil en jours/minutes selon le type
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Journal des actions automatisées
model AutomationLog {
  id         String   @id @default(cuid())
  type       String   // overdue_tasks, unpaid_invoices, meeting_reminder, email_followup
  action     String   // notification_sent, email_sent, reminder_created
  details    String?  // JSON with context details
  relatedId  String?  // ID de l'entité concernée
  success    Boolean  @default(true)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

/// Tags multi-dimensionnels avec couleur et catégorie
model Tag {
  id          String   @id @default(cuid())
  name        String
  color       String   @default("#10b981")
  icon        String?  // Nom d'icône Lucide
  category    String   @default("general") // urgent, client, status, billing, custom
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskTags    TaskTag[]
  emailTags   EmailTag[]
  documentTags DocumentTag[]
  projectTags ProjectTag[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, name])
}

/// Junction table: Task ↔ Tag
model TaskTag {
  id      String @id @default(cuid())
  taskId  String
  tagId   String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([taskId, tagId])
}

/// Junction table: Email ↔ Tag
model EmailTag {
  id      String @id @default(cuid())
  emailId String
  tagId   String
  email   Email  @relation(fields: [emailId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([emailId, tagId])
}

/// Junction table: Document ↔ Tag
model DocumentTag {
  id         String   @id @default(cuid())
  documentId String
  tagId      String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([documentId, tagId])
}

/// Junction table: Project ↔ Tag
model ProjectTag {
  id        String  @id @default(cuid())
  projectId String
  tagId     String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([projectId, tagId])
}

// ─── PRIORITÉ 3 — Différenciation ────────────────────────────────────────────

// Marketplace modules available for subscription
model Module {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g. "focus-mode", "client-portal", "slack-integration"
  name        String   // Display name
  description String?
  icon        String?  // Lucide icon name
  category    String   @default("productivity") // productivity, collaboration, integration, premium
  price       Float    @default(0) // Monthly price in EUR, 0 = free module
  features    String   @default("[]") // JSON array of feature descriptions
  isActive    Boolean  @default(true) // Admin can deactivate modules
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userModules UserModule[]

  @@index([slug])
  @@index([category, isActive])
}

// User subscription to a module (links to Stripe)
model UserModule {
  id        String   @id @default(cuid())
  userId    String
  moduleId  String
  status    String   @default("inactive") // trial, active, expired, cancelled
  expiresAt DateTime? // null = no expiration (lifetime or active subscription)
  stripePriceId String? // Links to Stripe price for billing
  trialStartsAt DateTime?
  trialEndsAt   DateTime?
  activatedAt   DateTime?
  cancelledAt   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId, status])
  @@index([expiresAt])
}

// Client portal invitations with signed tokens
model PortalInvite {
  id          String    @id @default(cuid())
  projectId   String
  token       String    @unique // Signed token (nanoid or JWT)
  email       String    // Client email
  clientName  String?   // Client display name
  expiresAt   DateTime  // Configurable expiration
  accessedAt  DateTime? // Last access timestamp
  accessCount Int       @default(0)
  isActive    Boolean   @default(true)
  createdById String    // The freelancer who created the invite
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Cascade)
  comments  PortalComment[]

  @@index([token])
  @@index([projectId, isActive])
  @@index([expiresAt])
}

// Client comments/approvals on portal
model PortalComment {
  id          String   @id @default(cuid())
  inviteId    String
  entityType  String   // "task", "document", "milestone"
  entityId    String   // ID of the entity being commented on
  action      String   @default("comment") // comment, approve, request_revision
  content     String?  // Comment text (required for comment, optional for approve/revision)
  authorName  String   // Client name
  authorEmail String   // Client email
  createdAt   DateTime @default(now())

  invite PortalInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@index([inviteId, entityType, entityId])
  @@index([createdAt])
}

// External service connections (Slack, Zoom, Drive, GitHub, Notion)
model IntegrationConnection {
  id            String   @id @default(cuid())
  userId        String
  provider      String   // slack, zoom, google_drive, github, notion
  accessToken   String?  // Encrypted OAuth access token
  refreshToken  String?  // Encrypted OAuth refresh token
  tokenExpiry   DateTime?
  scopes        String?  // JSON array of granted scopes
  metadata      String   @default("{}") // JSON: workspace_id, channel_id, repo, etc.
  status        String   @default("connected") // connected, error, expired, disconnected
  lastSyncAt    DateTime?
  lastError     String?  // Last sync error message
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId, status])
  @@index([provider])
}

// Focus mode / Pomodoro sessions
model FocusSession {
  id              String    @id @default(cuid())
  userId          String
  type            String    @default("pomodoro") // pomodoro, deep_work, custom
  durationMinutes Int       @default(25)
  breakMinutes    Int       @default(5)
  startedAt       DateTime
  endedAt         DateTime?
  pausedAt        DateTime? // When the session was paused (tab visibility)
  totalPausedSec  Int       @default(0) // Total seconds paused
  taskId          String?   // Linked task
  projectId       String?   // Linked project
  completed       Boolean   @default(false)
  ambientSound    String?   // rain, forest, cafe, fireplace, white_noise
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@index([userId, completed])
  @@index([taskId])
}

// Voice command logs
model VoiceLog {
  id          String   @id @default(cuid())
  userId      String
  transcript  String   // Raw speech-to-text
  intent      String?  // Parsed intent: create_task, open_emails, start_focus, etc.
  confidence  Float?   // Recognition confidence 0-1
  executed    Boolean  @default(false)
  error       String?  // Error message if execution failed
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([intent])
}

// ─── PRIORITÉ 4 — Production & Scale ───────────────────────────────────────

// Teams for multi-user collaboration
model Team {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique // URL-friendly identifier
  description       String?
  avatar            String?  // Team avatar URL
  plan              String   @default("free") // free, pro, enterprise
  stripeCustomerId  String?  // Stripe customer for team billing
  stripeSubscriptionId String? // Stripe subscription ID
  maxMembers        Int      @default(5) // Based on plan
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  members         TeamMember[]
  auditLogs       AuditLog[]
  pipelines       Pipeline[]
  crmContacts     CrmContact[]
  campaigns       Campaign[]
  workflows       Workflow[]
  emailTemplates  EmailTemplate[]

  @@index([slug])
  @@index([stripeCustomerId])
}

// Team membership with role-based access
model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      String   @default("member") // owner, admin, member, viewer (denormalized for quick reads)
  roleId    String?  // FK to RBAC Role
  status    String   @default("active") // active, invited, suspended, removed
  invitedAt DateTime @default(now())
  joinedAt  DateTime? // Set when user accepts invitation
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team    Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  roleRef Role? @relation(fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([userId, teamId])
  @@index([teamId, role])
  @@index([userId, status])
}

// Audit trail for teams and individual actions
model AuditLog {
  id        String   @id @default(cuid())
  teamId    String?  // Null for individual user actions
  userId    String
  action    String   // e.g. "team.member.invite", "export.create", "backup.restore"
  target    String?  // Entity type (user, project, invoice, etc.)
  targetId  String?  // Entity ID
  metadata  String   @default("{}") // JSON: additional context
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
}

// Async export/import jobs (CSV, JSON, PDF)
model ExportJob {
  id          String    @id @default(cuid())
  userId      String
  type        String    // export, import
  format      String    // csv, json, pdf
  entityType  String    // tasks, invoices, projects, time_entries, all
  status      String    @default("pending") // pending, processing, completed, failed
  filePath    String?   // Path to generated file (server-side)
  fileName    String?   // User-facing filename
  rowCount    Int       @default(0)
  errorCount  Int       @default(0)
  errorMessage String?
  fileSize    Int?      // File size in bytes
  startedAt   DateTime?
  completedAt DateTime?
  expiresAt   DateTime? // Signed URL expiration
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
}

// Database backup snapshots
model BackupSnapshot {
  id          String   @id @default(cuid())
  type        String   // hourly, daily, weekly, manual
  filePath    String   // Path to backup file
  fileSize    Int      // Size in bytes
  checksum    String   // SHA-256 checksum for integrity
  compressed  Boolean  @default(true)
  encrypted   Boolean  @default(true)
  status      String   @default("completed") // pending, completed, failed, restoring
  startedAt   DateTime @default(now())
  completedAt DateTime?
  errorMessage String?
  retentionUntil DateTime? // When this backup should be deleted
  createdAt   DateTime @default(now())

  @@index([type, createdAt])
  @@index([retentionUntil])
  @@index([status])
}

// Stripe webhook event processing (idempotency)
model WebhookEvent {
  id            String   @id @default(cuid())
  provider      String   // stripe
  eventId       String   @unique // Stripe event ID for dedup
  eventType     String   // checkout.session.completed, etc.
  processed     Boolean  @default(false)
  payload       String   // Raw JSON payload
  error         String?  // Processing error if any
  attempts      Int      @default(0)
  processedAt   DateTime?
  createdAt     DateTime @default(now())

  @@index([provider, processed])
  @@index([eventId])
  @@index([createdAt])
}

// User subscription management (Stripe-powered)
model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  stripeSubscriptionId String    @unique
  stripePriceId        String
  stripeCustomerId     String
  status               String    @default("active") // active, past_due, canceled, unpaid, trialing, paused
  trialStart           DateTime?
  trialEnd             DateTime?
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean   @default(false)
  canceledAt           DateTime?
  gracePeriodEnd       DateTime? // Extra time after payment failure
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([stripeCustomerId])
  @@index([currentPeriodEnd])
}

// Offline actions queue (synced when back online)
model OfflineAction {
  id         String   @id @default(cuid())
  userId     String
  actionType String   // create_task, create_note, create_email_draft, update_task
  entityType String   // task, note, email, time_entry
  entityId   String?  // Local ID (client-generated cuid)
  payload    String   // JSON payload of the action
  status     String   @default("pending") // pending, syncing, completed, failed
  attempts   Int      @default(0)
  error      String?
  createdAt  DateTime @default(now())
  syncedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
}

// ─── SUPERADMIN — Platform Administration ───────────────────────────────────

/// Superadmin audit log — every admin action is traced
model SuperAdminAuditLog {
  id         String   @id @default(cuid())
  userId     String   // The admin who performed the action
  action     String   // e.g. "user.suspend", "config.update", "flag.toggle", "impersonate.start"
  target     String?  // Entity type (user, subscription, config, flag, etc.)
  targetId   String?  // Entity ID
  metadata   String   @default("{}") // JSON: additional context (old/new values, reason, etc.)
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action])
  @@index([target, targetId])
  @@index([createdAt])
}

/// Platform-wide configuration key-value store
model PlatformConfig {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "maintenance_mode", "free_tier_limit", "default_currency"
  value     String   // JSON-encoded value
  type      String   @default("string") // string, number, boolean, json
  category  String   @default("general") // general, billing, features, legal, email
  description String?
  updatedAt  DateTime @updatedAt
  updatedBy String?  // Admin userId who last changed it

  @@index([category])
  @@index([key])
}

/// Feature flags for progressive rollout
model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "new_dashboard", "ai_copilot", "team_collaboration"
  name        String   // Display name
  description String?
  enabled     Boolean  @default(false) // Global on/off
  rollout     Int      @default(0) // Percentage 0-100 for gradual rollout
  segments    String   @default("[]") // JSON: user segments, regions, or userIds
  variants    String   @default("{}") // JSON: A/B test variants
  updatedBy   String?  // Admin userId who last changed it
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([key])
  @@index([enabled])
}

/// Support ticket tracking
model SupportTicket {
  id          String    @id @default(cuid())
  userId      String    // User who created the ticket
  subject     String
  description String
  status      String    @default("open") // open, in_progress, waiting_user, resolved, closed
  priority    String    @default("normal") // low, normal, high, urgent
  category    String    @default("general") // general, billing, technical, feature_request
  assignedTo  String?   // Admin userId
  resolution  String?   // Resolution notes
  firstResponseAt DateTime? // SLA tracking
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, status])
  @@index([status, priority])
  @@index([assignedTo])
  @@index([createdAt])
}

/// Impersonation session tracking (for security audit)
model ImpersonationSession {
  id          String    @id @default(cuid())
  adminUserId String    // The superadmin who initiated impersonation
  targetUserId String   // The user being impersonated
  token       String    @unique // Ephemeral JWT token
  reason      String?   // Reason for impersonation (mandatory in production)
  ip          String?
  expiresAt   DateTime  // Token expiration (max 15 min)
  endedAt     DateTime? // When the admin ended the session
  createdAt   DateTime  @default(now())

  @@index([adminUserId, createdAt])
  @@index([targetUserId])
  @@index([token])
  @@index([expiresAt])
}

// ─── LANDING PAGE — Marketing & Lead Capture ────────────────────────────────

/// Landing page lead/waitlist captures
model LandingLead {
  id        String   @id @default(cuid())
  email     String   // Validated email
  name      String?  // Optional first name
  source    String   @default("landing") // landing, newsletter, referral, utm_campaign
  utmSource String?  // UTM source parameter
  utmMedium String?  // UTM medium parameter
  utmCampaign String? // UTM campaign parameter
  utmContent String? // UTM content parameter
  referralCode String? // Referral code if applicable
  status    String   @default("pending") // pending, confirmed, unsubscribed, bounced
  confirmedAt DateTime? // Double opt-in confirmation
  createdAt DateTime @default(now())

  @@index([email])
  @@index([source])
  @@index([status])
  @@index([createdAt])
  @@index([utmCampaign])
}

// ─── PRIORITÉ 5 — Sécurité & Conformité ─────────────────────────────────────

/// 2FA Backup Codes - single-use recovery codes
model BackupCode {
  id        String   @id @default(cuid())
  codeHash  String   // bcrypt hash of the backup code
  usedAt    DateTime? // When the code was used (null = unused)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, usedAt])
}

/// GDPR Consent Log - tracks all consent actions
model ConsentLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  consentType String   // analytics, functional, marketing, essential
  action      String   // granted, revoked, updated
  version     String   // Policy version (e.g. "1.0")
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([userId, consentType])
  @@index([createdAt])
}

/// GDPR Data Request - tracks export/deletion requests
model GdprRequest {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String    // export, delete
  status      String    @default("pending") // pending, processing, completed, expired
  requestedAt DateTime  @default(now())
  completedAt DateTime?
  expiresAt   DateTime? // For export downloads (30 days)
  filePath    String?   // Path to generated archive
  fileSize    Int?      // Archive size in bytes
  ipAddress   String?
  userAgent   String?
  metadata    String    @default("{}") // JSON: additional context

  @@index([userId, status])
  @@index([status, requestedAt])
  @@index([expiresAt])
}

/// GDPR Grace Period Deletion - tracks accounts pending deletion
model GdprDeletionSchedule {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scheduledAt     DateTime  @default(now())
  gracePeriodEnd  DateTime  // 30 days from request
  confirmedAt     DateTime? // Double confirmation timestamp
  executedAt      DateTime? // When the actual deletion happened
  status          String    @default("pending") // pending, confirmed, executed, cancelled
  ipAddress       String?

  @@index([gracePeriodEnd])
  @@index([status])
}

/// Encryption Key Registry - tracks key versions for rotation
model EncryptionKey {
  id          String   @id @default(cuid())
  version     Int      @unique // Key version number (1, 2, 3...)
  algorithm   String   @default("aes-256-gcm")
  activeFrom  DateTime @default(now())
  activeUntil DateTime? // Null = currently active
  keyHash     String   // SHA-256 hash of the key for verification (not the key itself!)
  rotatedBy   String?  // Admin userId who rotated
  createdAt   DateTime @default(now())

  @@index([activeFrom])
  @@index([activeUntil])
}

/// Security Alert - anomalous behavior detection
model SecurityAlert {
  id          String   @id @default(cuid())
  userId      String?
  teamId      String?
  type        String   // multiple_ip_login, bulk_export, bulk_delete, brute_force, role_change
  severity    String   @default("medium") // low, medium, high, critical
  status      String   @default("active") // active, acknowledged, resolved, false_positive
  description String
  metadata    String   @default("{}") // JSON: IPs, counts, timestamps, etc.
  ipAddress   String?
  resolvedBy  String?  // Admin userId who resolved
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  @@index([userId, status])
  @@index([type, severity])
  @@index([status, createdAt])
  @@index([teamId])
}

/// RBAC Permission - defines granular permissions
model Permission {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g. "task:create", "invoice:delete", "team:manage"
  resource    String   // e.g. "task", "invoice", "team", "billing", "settings"
  action      String   // create, read, update, delete, manage, export
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@index([resource])
  @@index([action])
  @@unique([resource, action])
}

/// RBAC Role - defines hierarchical roles
model Role {
  id          String   @id @default(cuid())
  slug        String   @unique // superadmin, owner, admin, member, viewer, guest
  name        String   // Display name
  description String?
  level       Int      @default(0) // Hierarchy level: 0=guest, 100=superadmin
  isDefault   Boolean  @default(false) // Default role for new users
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]
  teamMembers     TeamMember[]

  @@index([slug])
  @@index([level])
}

/// RBAC Role-Permission Junction
model RolePermission {
  id           String   @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

/// DPO Contact Request - Data Protection Officer communications
model DpoContact {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name        String
  email       String
  subject     String
  message     String
  status      String   @default("open") // open, in_progress, resolved, closed
  response    String?  // DPO response
  resolvedBy  String?  // Admin userId
  resolvedAt  DateTime?
  ipAddress   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ─── UNIFIED INBOX — Messagerie Multi-Canaux ──────────────────────────────────

/// Unified Contact — single view of a person across all channels
model Contact {
  id              String   @id @default(cuid())
  name            String
  emails          String   @default("[]") // JSON string[]
  phones          String   @default("[]") // JSON string[]
  slackId         String?
  telegramId      String?
  preferredChannel String  @default("email") // email, whatsapp, sms, slack
  customFields    String   @default("{}") // JSON: arbitrary key-value pairs
  tags            String   @default("[]") // JSON string[]
  avatar          String?
  company         String?
  notes           String?
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversations   ConversationParticipant[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([name])
}

/// Channel Account — connected provider accounts (Gmail, Outlook, WhatsApp, etc.)
model ChannelAccount {
  id              String    @id @default(cuid())
  userId          String
  provider        String    // gmail, outlook, whatsapp, twilio, slack
  email           String?   // Account email (for email providers)
  accountId       String?   // Provider-specific account ID
  accessToken     String?   // Encrypted OAuth access token (AES-256-GCM)
  refreshToken    String?   // Encrypted OAuth refresh token
  tokenExpiry     DateTime?
  scopes          String?   // JSON array of granted scopes
  config          String    @default("{}") // JSON: provider-specific config (historyId, deltaToken, etc.)
  isActive        Boolean   @default(true)
  lastSyncAt      DateTime?
  lastSyncCursor  String?   // Gmail historyId, Outlook deltaToken, etc.
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId, isActive])
  @@index([provider])
}

/// Conversation — unified thread across any channel
model Conversation {
  id                String    @id @default(cuid())
  externalThreadId  String?   // Provider's thread/message ID
  channel           String    @default("email") // email, whatsapp, sms, slack
  status            String    @default("open") // open, pending, closed, spam
  priority          String    @default("normal") // low, normal, high, urgent
  subject           String?   // Email subject or chat topic
  lastActivityAt    DateTime  @default(now())
  assignedToId      String?   // User ID of assigned agent
  projectId         String?   // Linked project
  tags              String    @default("[]") // JSON string[]
  metadata          String    @default("{}") // JSON: channel-specific data (headers, msgIds, etc.)
  isStarred         Boolean   @default(false)
  unreadCount       Int       @default(0)
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages          InboxMessage[]
  participants      ConversationParticipant[]
  internalNotes     InternalNote[]
  events            ConversationEvent[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId, status, lastActivityAt])
  @@index([userId, channel])
  @@index([assignedToId])
  @@index([projectId])
  @@index([lastActivityAt])
}

/// Conversation Participant — links contacts to conversations
model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  contactId      String
  role           String   @default("participant") // sender, recipient, cc, bcc
  channelId      String?  // Channel-specific identifier (email address, phone, etc.)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact      Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([conversationId, contactId])
  @@index([conversationId])
  @@index([contactId])
}

/// Inbox Message — individual message within a conversation
model InboxMessage {
  id              String    @id @default(cuid())
  conversationId  String
  direction       String    @default("inbound") // inbound, outbound, internal
  channel         String    @default("email") // email, whatsapp, sms, slack
  subject         String?
  body            String?   // Markdown content
  bodyHtml        String?   // Original HTML (for email)
  attachments     String    @default("[]") // JSON: [{name, url, mimeType, size}]
  metadata        String    @default("{}") // JSON: headers, phones, msgIds, etc.
  status          String    @default("delivered") // pending, sent, delivered, read, failed
  deliveredAt     DateTime?
  readAt          DateTime?
  aiDraft         Boolean   @default(false) // Generated by AI
  aiContextUsed   String    @default("{}") // JSON: what context was used for AI generation
  senderName      String?
  senderEmail     String?
  externalId      String?   // Provider's message ID (for dedup)
  userId          String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([conversationId, createdAt])
  @@index([userId, status])
  @@index([externalId])
  @@index([createdAt])
}

/// Internal Note — private team notes on a conversation
model InternalNote {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  content        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([userId])
}

/// Conversation Event — audit trail for conversations
model ConversationEvent {
  id             String   @id @default(cuid())
  conversationId String
  type           String   // created, assigned, status_changed, note_added, message_sent, etc.
  userId         String?
  metadata       String   @default("{}") // JSON: event-specific data
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([type])
}

// ─── CRM & AUTOMATION ──────────────────────────────────────────────────────────

/// Workspace — multi-tenant isolation unit (extends Team concept for CRM)
model Workspace {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  description   String?
  avatar        String?
  plan          String   @default("free") // free, pro, enterprise
  settings      String   @default("{}") // JSON: workspace-level settings
  ownerUserId   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members       WorkspaceMember[]

  @@index([slug])
  @@index([ownerUserId])
}

/// Workspace Member — multi-tenant membership
model WorkspaceMember {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        String   @default("agent") // owner, admin, agent, viewer
  status      String   @default("active") // active, invited, suspended, removed
  joinedAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId, role])
  @@index([userId, status])
}

/// CRM Contact — rich contact profile with custom fields
model CrmContact {
  id            String    @id @default(cuid())
  workspaceId   String?   // Multi-tenant isolation
  teamId        String?   // Team isolation
  firstName     String?
  lastName      String
  email         String?
  phone         String?
  company       String?
  jobTitle      String?
  avatar        String?
  addresses     String    @default("[]") // JSON: [{type, street, city, zip, country}]
  customFields  String    @default("{}") // JSON: dynamic key-value pairs
  tags          String    @default("[]") // JSON: array of tag strings
  source        String    @default("manual") // manual, import, form, api, referral
  status        String    @default("active") // active, inactive, bounced, unsubscribed
  lifecycle     String    @default("lead") // lead, qualified, opportunity, customer, churned
  score         Int       @default(0) // Lead score 0-100
  lastActivityAt DateTime?
  userId        String    // Owner/assigned user
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  groups    ContactGroupMember[]
  segments  ContactSegmentMember[]
  activities ActivityTimeline[]
  notes     ContactNote[]
  deals     Deal[]

  @@index([userId, status])
  @@index([teamId, status])
  @@index([email])
  @@index([lifecycle])
  @@index([score])
  @@index([lastActivityAt])
  @@index([source])
}

/// Contact Group — static lists for segmentation
model ContactGroup {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#10b981")
  icon        String?
  isDynamic   Boolean  @default(false) // true = auto-populated via rules
  rules       String   @default("[]") // JSON: [{field, operator, value}] for dynamic groups
  userId      String
  teamId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members ContactGroupMember[]

  @@index([userId])
  @@index([teamId])
}

/// Junction: Contact ↔ Group
model ContactGroupMember {
  id        String @id @default(cuid())
  contactId String
  groupId   String
  contact   CrmContact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  group     ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([contactId, groupId])
}

/// Contact Segment Member — for dynamic segmentation
model ContactSegmentMember {
  id        String @id @default(cuid())
  contactId String
  segmentId String
  contact   CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([contactId, segmentId])
}

/// Activity Timeline — unified activity log per contact
model ActivityTimeline {
  id          String   @id @default(cuid())
  contactId   String
  type        String   // email_sent, email_opened, call_made, note_added, deal_created, campaign_sent, form_submitted, tag_added
  title       String
  description String?
  metadata    String   @default("{}") // JSON: type-specific data (email subject, call duration, etc.)
  relatedId   String?  // ID of the related entity (deal, campaign, email, etc.)
  relatedType String?  // deal, campaign, email, call, note
  userId      String?  // Who performed the action
  createdAt   DateTime @default(now())

  contact CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, createdAt])
  @@index([type])
  @@index([userId])
}

/// Contact Note — internal notes linked to a contact
model ContactNote {
  id        String   @id @default(cuid())
  contactId String
  content   String   // Markdown content
  isPinned  Boolean  @default(false)
  userId    String   // Author
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact CrmContact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId, createdAt])
  @@index([isPinned])
}

/// Pipeline — sales pipeline with configurable stages
model Pipeline {
  id          String   @id @default(cuid())
  name        String
  description String?
  stages      String   @default("[]") // JSON: [{id, name, order, color, probability}] e.g. [{id:"s1",name:"Qualified",order:1,color:"#3b82f6",probability:20}]
  isDefault   Boolean  @default(false)
  teamId      String?  // Team-scoped pipeline
  userId      String   // Owner
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  deals Deal[]

  @@index([userId])
  @@index([teamId])
}

/// Deal — opportunity in a pipeline stage
model Deal {
  id               String    @id @default(cuid())
  pipelineId       String
  stageId          String    // References a stage id within pipeline.stages JSON
  title            String
  description      String?
  value            Float     @default(0)
  currency         String    @default("EUR")
  probability      Int       @default(0) // 0-100, can be auto-set by stage
  expectedCloseDate DateTime?
  actualCloseDate  DateTime?
  status           String    @default("open") // open, won, lost, abandoned
  lossReason       String?
  contactId        String?
  assignedToId     String?   // User responsible for the deal
  userId           String    // Deal owner
  teamId           String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  pipeline    Pipeline   @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  contact     CrmContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  assignedTo  User?      @relation("DealAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  user        User       @relation("DealOwner", fields: [userId], references: [id], onDelete: Cascade)
  activities  DealActivity[]

  @@index([pipelineId, stageId])
  @@index([status])
  @@index([assignedToId])
  @@index([contactId])
  @@index([expectedCloseDate])
  @@index([userId])
}

/// Deal Activity — audit trail for deal changes
model DealActivity {
  id        String   @id @default(cuid())
  dealId    String
  type      String   // created, stage_changed, value_updated, assigned, note_added, status_changed
  note      String?
  metadata  String   @default("{}") // JSON: {oldStage, newStage, oldValue, newValue, etc.}
  userId    String?
  createdAt DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId, createdAt])
  @@index([type])
}

/// Email Campaign
model Campaign {
  id              String    @id @default(cuid())
  name            String
  subject         String
  fromName        String?
  fromEmail       String?
  replyTo         String?
  previewText     String?
  contentHtml     String?   // HTML body (MJML compiled or raw)
  contentMjml     String?   // MJML source (optional)
  status          String    @default("draft") // draft, scheduled, sending, sent, paused, cancelled
  scheduleAt      DateTime?
  throttlePerHour Int       @default(0) // 0 = unlimited, otherwise max emails/hour
  segmentIds      String    @default("[]") // JSON: array of group/segment IDs
  templateId      String?   // Optional linked template
  senderAddress   String?   // CAN-SPAM: physical address
  listUnsubscribe Boolean   @default(true) // CAN-SPAM: List-Unsubscribe header
  doubleOptIn     Boolean   @default(false) // Require confirmation
  stats           String    @default("{}") // JSON: {sent, delivered, opened, clicked, bounced, unsubscribed, complained}
  userId          String
  teamId          String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  recipients CampaignRecipient[]
  links      CampaignLink[]

  @@index([userId, status])
  @@index([teamId, status])
  @@index([status, scheduleAt])
}

/// Campaign Recipient — per-contact delivery tracking
model CampaignRecipient {
  id             String    @id @default(cuid())
  campaignId     String
  contactId      String
  email          String    // Snapshot of email at send time
  status         String    @default("pending") // pending, sent, delivered, bounced, failed
  sentAt         DateTime?
  openedAt       DateTime?
  openCount      Int       @default(0)
  clickedAt      DateTime?
  clickCount     Int       @default(0)
  unsubscribedAt DateTime?
  complainedAt   DateTime?
  bouncedAt      DateTime?
  bounceReason   String?
  trackingPixel  String?   // Unique pixel ID for open tracking
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactId])
  @@index([campaignId, status])
  @@index([contactId])
  @@index([status])
}

/// Campaign Link — click tracking
model CampaignLink {
  id            String @id @default(cuid())
  campaignId    String
  originalUrl   String
  trackingUrl   String // Signed redirect URL
  trackingId    String @unique // Unique ID in the redirect URL
  clicks        Int    @default(0)
  uniqueClicks  Int    @default(0)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([trackingId])
}

/// Workflow Automation — event-driven rules
model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  trigger     String   @default("{}") // JSON: {type: "contact.created"|"deal.stage_changed"|"email.received"|"tag.added"|"campaign.opened"|"date.reached", config: {...}}
  actions     String   @default("[]") // JSON: [{type: "email.send"|"tag.add"|"assign.to"|"create.task"|"delay.hours"|"webhook.call"|"ai.generate_reply", config: {...}}]
  isActive    Boolean  @default(true)
  isTest      Boolean  @default(false) // Test mode = log only, no execution
  stats       String   @default("{}") // JSON: {totalExecutions, successCount, failureCount, lastExecutedAt}
  userId      String
  teamId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team        Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  executions  WorkflowExecution[]

  @@index([userId, isActive])
  @@index([teamId, isActive])
  @@index([isActive])
}

/// Workflow Execution — tracks each run
model WorkflowExecution {
  id            String    @id @default(cuid())
  workflowId    String
  contactId     String?
  conversationId String?
  dealId        String?
  status        String    @default("running") // running, completed, failed, cancelled, delayed
  currentStep   Int       @default(0) // Index in actions array
  logs          String    @default("[]") // JSON: [{step, action, status, output, timestamp, error}]
  idempotencyKey String?  // For dedup
  scheduledAt   DateTime? // For delayed actions
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  error         String?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, status])
  @@index([contactId])
  @@index([status, scheduledAt])
  @@index([idempotencyKey])
}

/// Email Template — for campaigns and canned responses
model EmailTemplate {
  id          String   @id @default(cuid())
  name        String
  subject     String?
  contentHtml String    // HTML with {{variable}} placeholders
  contentMjml String?   // MJML source (optional)
  variables   String   @default("[]") // JSON: [{key, label, defaultValue, required}]
  category    String   @default("general") // general, onboarding, follow_up, newsletter, transactional
  shortcut    String?  // Quick insert via "/" in editor (e.g. "/welcome")
  isShared    Boolean  @default(true) // Visible to team or private
  isDefault   Boolean  @default(false)
  thumbnail   String?  // Preview image URL
  userId      String
  teamId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)

  @@index([userId, category])
  @@index([teamId, isShared])
  @@index([shortcut])
}

/// Metric Snapshot — pre-computed analytics data
model MetricSnapshot {
  id          String   @id @default(cuid())
  teamId      String?
  userId      String
  type        String   // crm_contacts, pipeline_value, campaign_stats, response_time, agent_performance
  period      String   // hourly, daily, weekly, monthly
  date        DateTime // The date this snapshot covers
  data        String   @default("{}") // JSON: metric-specific data
  computedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, period, date])
  @@index([teamId, type, date])
  @@index([userId, type])
  @@index([date])
}

/// Report Cache — cached report data
model ReportCache {
  id        String   @id @default(cuid())
  key       String   @unique // Composite key: {type}:{userId}:{period}:{dateRange}
  data      String   // JSON: report data
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([key])
  @@index([expiresAt])
}

// ─── FISCALY — QR Carte d'Identité Commerciale ────────────────────────────────

/// Merchant — commerce inscrit sur la plateforme Fiscaly
model Merchant {
  id            String   @id @default(cuid())
  userId        String   // Lien vers le User propriétaire
  commerceName  String   // Nom du commerce (affiché publiquement)
  activity      String   // Type d'activité (boulangerie, restaurant, etc.)
  quartier      String   // Quartier / zone (affiché publiquement)
  latitude      Float    // Latitude GPS pour géofencing
  longitude     Float    // Longitude GPS pour géofencing
  photoUrl      String?  // Photo du commerce (visible agent uniquement)
  phone         String?  // Téléphone (JAMAIS exposé publiquement)
  taxAmount     Float    @default(0) // Montant de la taxe fiscale
  currency      String   @default("XOF") // Devise
  paymentStatus String   @default("up_to_date") // up_to_date, overdue
  dueDate       DateTime? // Date d'échéance du paiement
  lastPaidAt    DateTime? // Dernier paiement
  tenantId      String?  // Multi-tenant (organisation)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  badges  FiscalBadge[]
  scanLogs BadgeScanLog[]
  payments PaymentTransaction[]

  @@index([userId])
  @@index([paymentStatus])
  @@index([tenantId])
}

/// FiscalBadge — Badge QR avec token signé
model FiscalBadge {
  id          String    @id @default(cuid())
  merchantId  String    // Lien vers le commerce
  token       String    @unique // JWT signé encodé dans le QR
  status      String    @default("ACTIVE") // ACTIVE, REVOKED, EXPIRED
  issuedAt    DateTime  @default(now()) // Date d'émission du token
  expiresAt   DateTime  // Expiration du token (1 an)
  revokedAt   DateTime? // Date de révocation (si applicable)
  revokedBy   String?   // ID de l'utilisateur ayant révoqué
  lastScannedAt DateTime? // Dernier scan
  scanCount   Int       @default(0) // Nombre de scans total
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  merchant Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  scanLogs BadgeScanLog[]

  @@index([token])
  @@index([merchantId, status])
  @@index([expiresAt])
  @@index([status])
}

/// BadgeScanLog — Journal immuable de chaque scan (public & agent)
model BadgeScanLog {
  id          String   @id @default(cuid())
  badgeId     String   // Lien vers le badge
  merchantId  String   // Lien vers le commerce (dénormalisé pour requêtes rapides)
  scanType    String   // public, agent
  agentId     String?  // ID de l'agent (si scan agent)
  agentLat    Float?   // Latitude GPS de l'agent au scan
  agentLng    Float?   // Longitude GPS de l'agent au scan
  distance    Float?   // Distance en mètres entre agent et commerce
  geoStatus   String?  // OK, FRAUD_GPS, TOO_FAR (si scan agent)
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  badge    FiscalBadge @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  merchant Merchant    @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  @@index([badgeId, createdAt])
  @@index([merchantId, createdAt])
  @@index([scanType])
  @@index([agentId])
  @@index([geoStatus])
}

/// PaymentTransaction — Transactions de paiement validées par agent
model PaymentTransaction {
  id              String    @id @default(cuid())
  merchantId      String    // Commerce concerné
  badgeId         String    // Badge scanné lors du paiement
  agentId         String    // Agent ayant validé
  amount          Float     // Montant payé
  currency        String    @default("XOF")
  paymentMethod   String    // cash, mobile_money, card, bank_transfer
  reference       String?   // Référence de paiement
  proofPhotoUrl   String?   // Photo preuve de paiement
  agentLat        Float     // Latitude GPS de l'agent
  agentLng        Float     // Longitude GPS de l'agent
  distance        Float     // Distance en mètres
  geoStatus       String    // OK, FRAUD_GPS
  status          String    @default("completed") // completed, disputed, refunded
  createdAt       DateTime  @default(now())

  merchant Merchant     @relation(fields: [merchantId], references: [id], onDelete: Cascade)
  agent    User         @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([merchantId, createdAt])
  @@index([agentId, createdAt])
  @@index([status])
}
