generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  avatar        String?
  passwordHash  String?  // null for OAuth-only users
  profession    String?
  timezone      String   @default("Europe/Paris")
  assistantName String   @default("Burofree AI")
  assistantTone String   @default("friendly")
  theme         String   @default("dark")
  focusMode     Boolean  @default(false)
  onboardingDone       Boolean  @default(false)
  hourlyRate            Float?
  weeklyTargetHours     Float?
  weeklyTargetRevenue   Float?
  maxDailyHours         Float?
  stripeAccountId       String?
  stripeCustomerId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tasks         Task[]
  events        CalendarEvent[]
  reminders     Reminder[]
  emailAccounts EmailAccount[]
  accounts      Account[]
  sessions      Session[]
  projects      Project[]
  invoices      Invoice[]
  timeEntries   TimeEntry[]
  documents     Document[]
  snippets      Snippet[]
  notifications     Notification[]
  goals             WeeklyGoal[]
  chatMessages      ChatMessage[]
  pushSubscriptions PushSubscription[]
  meetings          Meeting[]
  contracts         Contract[]
  templates         Template[]
  automationPrefs   AutomationPreference[]
  automationLogs    AutomationLog[]
  tags              Tag[]
  modules           UserModule[]
  portalInvites     PortalInvite[]
  integrations      IntegrationConnection[]
  focusSessions     FocusSession[]
  voiceLogs         VoiceLog[]
  teamMemberships   TeamMember[]
  auditLogs         AuditLog[]
  exportJobs        ExportJob[]
  subscriptions     Subscription[]
  offlineActions    OfflineAction[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  clientName  String?
  color       String   @default("#10b981")
  status      String   @default("active")
  budget      Float?
  deadline    DateTime?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]
  invoices    Invoice[]
  documents   Document[]
  timeEntries TimeEntry[]
  meetings    Meeting[]
  contracts   Contract[]
  tags           ProjectTag[]
  portalInvites  PortalInvite[]
  focusSessions  FocusSession[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Task {
  id            String    @id @default(cuid())
  title         String
  description   String?
  status        String    @default("todo")
  priority      String    @default("medium")
  dueDate       DateTime?
  reminderAt    DateTime?
  completedAt   DateTime?
  category      String?
  estimatedTime Int?
  actualTime    Int?
  recurrence    String?
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  timeEntries   TimeEntry[]
  tags          TaskTag[]
  focusSessions FocusSession[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model CalendarEvent {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  color       String    @default("#10b981")
  allDay      Boolean   @default(false)
  location    String?
  type        String    @default("meeting")
  source      String    @default("local")
  sourceId    String?   @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Reminder {
  id          String   @id @default(cuid())
  title       String
  message     String?
  remindAt    DateTime
  isSent      Boolean  @default(false)
  type        String   @default("in_app")
  relatedId   String?
  relatedType String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EmailAccount {
  id              String    @id @default(cuid())
  provider        String
  email           String
  accessToken     String?
  refreshToken    String?
  tokenExpiry     DateTime?
  scopes          String?
  imapHost        String?
  imapPort        Int?
  smtpHost        String?
  smtpPort        Int?
  isPrimary       Boolean   @default(false)
  gmailHistoryId  String?
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  emails          Email[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Email {
  id             String      @id @default(cuid())
  fromAddress    String
  fromName       String?
  toAddress      String
  subject        String
  body           String?
  snippet        String?
  isRead         Boolean     @default(false)
  isStarred      Boolean     @default(false)
  isSent         Boolean     @default(false)
  category       String      @default("client")
  hasTask        Boolean     @default(false)
  scheduledAt    DateTime?
  source         String      @default("local")
  sourceId       String?     @unique
  emailAccountId String
  emailAccount   EmailAccount @relation(fields: [emailAccountId], references: [id], onDelete: Cascade)
  userId         String
  tags           EmailTag[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

model Invoice {
  id                     String    @id @default(cuid())
  number                 String
  type                   String    @default("invoice")
  clientName             String
  clientEmail            String?
  clientAddress          String?
  items                  String
  subtotal               Float
  taxRate                Float     @default(20.0)
  taxAmount              Float
  total                  Float
  currency               String    @default("EUR")
  status                 String    @default("draft")
  dueDate                DateTime?
  paidAt                 DateTime?
  notes                  String?
  stripePaymentIntentId  String?
  stripeCheckoutUrl      String?
  paymentMethod          String    @default("manual")
  projectId              String?
  project                Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId                 String
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model TimeEntry {
  id          String   @id @default(cuid())
  startTime   DateTime
  endTime     DateTime?
  duration    Int?
  description String?
  isBillable  Boolean  @default(true)
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Document {
  id        String   @id @default(cuid())
  name      String
  type      String
  content   String?
  fileUrl   String?
  mimeType  String?
  size      Int?
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tags      DocumentTag[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Snippet {
  id        String   @id @default(cuid())
  title     String
  content   String
  category  String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  channel   String   @default("in_app")
  isRead    Boolean  @default(false)
  actionUrl String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WeeklyGoal {
  id        String   @id @default(cuid())
  title     String
  target    Int?
  current   Int      @default(0)
  unit      String   @default("tasks")
  weekStart DateTime
  weekEnd   DateTime
  completed Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Meeting {
  id          String    @id @default(cuid())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime?
  location    String?
  meetingUrl  String?    // Zoom, Google Meet, Teams link
  type        String     @default("video") // video, phone, in_person
  status      String     @default("scheduled") // scheduled, completed, cancelled
  agenda      String?    // Meeting agenda (markdown)
  notes       String?    // Meeting notes/minutes (markdown)
  projectId   String?
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Contract {
  id             String    @id @default(cuid())
  title          String
  description    String?
  type           String     @default("service") // service, nda, partnership, freelance
  status         String     @default("draft") // draft, sent, signed, active, expired, terminated
  clientName     String
  clientEmail    String?
  clientAddress  String?
  startDate      DateTime?
  endDate        DateTime?
  value          Float?     // Contract value
  currency       String     @default("EUR")
  terms          String?    // Contract terms (markdown)
  notes          String?
  fileUrl        String?    // Uploaded contract file
  projectId      String?
  project        Project?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

// ─── PRIORITÉ 2 — Productivité ───────────────────────────────────────────────────

/// Système de templates réutilisables avec variables dynamiques
model Template {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        String   // contract, quote, email, project_structure, client_response
  content     String   // Contenu avec variables {client_name}, {date}, etc.
  variables   String   @default("[]") // JSON array of variable names
  category    String   @default("general") // Catégorie pour le tri
  icon        String?  // Nom d'icône Lucide
  isDefault   Boolean  @default(false) // Template prédéfini
  usageCount  Int      @default(0)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

/// Préférences utilisateur pour les rappels automatiques
model AutomationPreference {
  id        String   @id @default(cuid())
  type      String   // overdue_tasks, unpaid_invoices, meeting_reminder, email_followup
  enabled   Boolean  @default(true)
  channel   String   @default("in_app") // in_app, email, both
  frequency String   @default("15min") // 15min, 30min, 1h, daily
  threshold Int      @default(7) // Seuil en jours/minutes selon le type
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Journal des actions automatisées
model AutomationLog {
  id         String   @id @default(cuid())
  type       String   // overdue_tasks, unpaid_invoices, meeting_reminder, email_followup
  action     String   // notification_sent, email_sent, reminder_created
  details    String?  // JSON with context details
  relatedId  String?  // ID de l'entité concernée
  success    Boolean  @default(true)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

/// Tags multi-dimensionnels avec couleur et catégorie
model Tag {
  id          String   @id @default(cuid())
  name        String
  color       String   @default("#10b981")
  icon        String?  // Nom d'icône Lucide
  category    String   @default("general") // urgent, client, status, billing, custom
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskTags    TaskTag[]
  emailTags   EmailTag[]
  documentTags DocumentTag[]
  projectTags ProjectTag[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, name])
}

/// Junction table: Task ↔ Tag
model TaskTag {
  id      String @id @default(cuid())
  taskId  String
  tagId   String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([taskId, tagId])
}

/// Junction table: Email ↔ Tag
model EmailTag {
  id      String @id @default(cuid())
  emailId String
  tagId   String
  email   Email  @relation(fields: [emailId], references: [id], onDelete: Cascade)
  tag     Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([emailId, tagId])
}

/// Junction table: Document ↔ Tag
model DocumentTag {
  id         String   @id @default(cuid())
  documentId String
  tagId      String
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([documentId, tagId])
}

/// Junction table: Project ↔ Tag
model ProjectTag {
  id        String  @id @default(cuid())
  projectId String
  tagId     String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag       Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([projectId, tagId])
}

// ─── PRIORITÉ 3 — Différenciation ────────────────────────────────────────────

// Marketplace modules available for subscription
model Module {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g. "focus-mode", "client-portal", "slack-integration"
  name        String   // Display name
  description String?
  icon        String?  // Lucide icon name
  category    String   @default("productivity") // productivity, collaboration, integration, premium
  price       Float    @default(0) // Monthly price in EUR, 0 = free module
  features    String   @default("[]") // JSON array of feature descriptions
  isActive    Boolean  @default(true) // Admin can deactivate modules
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userModules UserModule[]

  @@index([slug])
  @@index([category, isActive])
}

// User subscription to a module (links to Stripe)
model UserModule {
  id        String   @id @default(cuid())
  userId    String
  moduleId  String
  status    String   @default("inactive") // trial, active, expired, cancelled
  expiresAt DateTime? // null = no expiration (lifetime or active subscription)
  stripePriceId String? // Links to Stripe price for billing
  trialStartsAt DateTime?
  trialEndsAt   DateTime?
  activatedAt   DateTime?
  cancelledAt   DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@unique([userId, moduleId])
  @@index([userId, status])
  @@index([expiresAt])
}

// Client portal invitations with signed tokens
model PortalInvite {
  id          String    @id @default(cuid())
  projectId   String
  token       String    @unique // Signed token (nanoid or JWT)
  email       String    // Client email
  clientName  String?   // Client display name
  expiresAt   DateTime  // Configurable expiration
  accessedAt  DateTime? // Last access timestamp
  accessCount Int       @default(0)
  isActive    Boolean   @default(true)
  createdById String    // The freelancer who created the invite
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Cascade)
  comments  PortalComment[]

  @@index([token])
  @@index([projectId, isActive])
  @@index([expiresAt])
}

// Client comments/approvals on portal
model PortalComment {
  id          String   @id @default(cuid())
  inviteId    String
  entityType  String   // "task", "document", "milestone"
  entityId    String   // ID of the entity being commented on
  action      String   @default("comment") // comment, approve, request_revision
  content     String?  // Comment text (required for comment, optional for approve/revision)
  authorName  String   // Client name
  authorEmail String   // Client email
  createdAt   DateTime @default(now())

  invite PortalInvite @relation(fields: [inviteId], references: [id], onDelete: Cascade)

  @@index([inviteId, entityType, entityId])
  @@index([createdAt])
}

// External service connections (Slack, Zoom, Drive, GitHub, Notion)
model IntegrationConnection {
  id            String   @id @default(cuid())
  userId        String
  provider      String   // slack, zoom, google_drive, github, notion
  accessToken   String?  // Encrypted OAuth access token
  refreshToken  String?  // Encrypted OAuth refresh token
  tokenExpiry   DateTime?
  scopes        String?  // JSON array of granted scopes
  metadata      String   @default("{}") // JSON: workspace_id, channel_id, repo, etc.
  status        String   @default("connected") // connected, error, expired, disconnected
  lastSyncAt    DateTime?
  lastError     String?  // Last sync error message
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId, status])
  @@index([provider])
}

// Focus mode / Pomodoro sessions
model FocusSession {
  id              String    @id @default(cuid())
  userId          String
  type            String    @default("pomodoro") // pomodoro, deep_work, custom
  durationMinutes Int       @default(25)
  breakMinutes    Int       @default(5)
  startedAt       DateTime
  endedAt         DateTime?
  pausedAt        DateTime? // When the session was paused (tab visibility)
  totalPausedSec  Int       @default(0) // Total seconds paused
  taskId          String?   // Linked task
  projectId       String?   // Linked project
  completed       Boolean   @default(false)
  ambientSound    String?   // rain, forest, cafe, fireplace, white_noise
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([userId, startedAt])
  @@index([userId, completed])
  @@index([taskId])
}

// Voice command logs
model VoiceLog {
  id          String   @id @default(cuid())
  userId      String
  transcript  String   // Raw speech-to-text
  intent      String?  // Parsed intent: create_task, open_emails, start_focus, etc.
  confidence  Float?   // Recognition confidence 0-1
  executed    Boolean  @default(false)
  error       String?  // Error message if execution failed
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([intent])
}

// ─── PRIORITÉ 4 — Production & Scale ───────────────────────────────────────

// Teams for multi-user collaboration
model Team {
  id                String   @id @default(cuid())
  name              String
  slug              String   @unique // URL-friendly identifier
  description       String?
  avatar            String?  // Team avatar URL
  plan              String   @default("free") // free, pro, enterprise
  stripeCustomerId  String?  // Stripe customer for team billing
  stripeSubscriptionId String? // Stripe subscription ID
  maxMembers        Int      @default(5) // Based on plan
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  members    TeamMember[]
  auditLogs  AuditLog[]

  @@index([slug])
  @@index([stripeCustomerId])
}

// Team membership with role-based access
model TeamMember {
  id        String   @id @default(cuid())
  userId    String
  teamId    String
  role      String   @default("member") // owner, admin, member, viewer
  status    String   @default("active") // active, invited, suspended, removed
  invitedAt DateTime @default(now())
  joinedAt  DateTime? // Set when user accepts invitation
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([teamId, role])
  @@index([userId, status])
}

// Audit trail for teams and individual actions
model AuditLog {
  id        String   @id @default(cuid())
  teamId    String?  // Null for individual user actions
  userId    String
  action    String   // e.g. "team.member.invite", "export.create", "backup.restore"
  target    String?  // Entity type (user, project, invoice, etc.)
  targetId  String?  // Entity ID
  metadata  String   @default("{}") // JSON: additional context
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  team Team? @relation(fields: [teamId], references: [id], onDelete: SetNull)
  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([teamId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
}

// Async export/import jobs (CSV, JSON, PDF)
model ExportJob {
  id          String    @id @default(cuid())
  userId      String
  type        String    // export, import
  format      String    // csv, json, pdf
  entityType  String    // tasks, invoices, projects, time_entries, all
  status      String    @default("pending") // pending, processing, completed, failed
  filePath    String?   // Path to generated file (server-side)
  fileName    String?   // User-facing filename
  rowCount    Int       @default(0)
  errorCount  Int       @default(0)
  errorMessage String?
  fileSize    Int?      // File size in bytes
  startedAt   DateTime?
  completedAt DateTime?
  expiresAt   DateTime? // Signed URL expiration
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
}

// Database backup snapshots
model BackupSnapshot {
  id          String   @id @default(cuid())
  type        String   // hourly, daily, weekly, manual
  filePath    String   // Path to backup file
  fileSize    Int      // Size in bytes
  checksum    String   // SHA-256 checksum for integrity
  compressed  Boolean  @default(true)
  encrypted   Boolean  @default(true)
  status      String   @default("completed") // pending, completed, failed, restoring
  startedAt   DateTime @default(now())
  completedAt DateTime?
  errorMessage String?
  retentionUntil DateTime? // When this backup should be deleted
  createdAt   DateTime @default(now())

  @@index([type, createdAt])
  @@index([retentionUntil])
  @@index([status])
}

// Stripe webhook event processing (idempotency)
model WebhookEvent {
  id            String   @id @default(cuid())
  provider      String   // stripe
  eventId       String   @unique // Stripe event ID for dedup
  eventType     String   // checkout.session.completed, etc.
  processed     Boolean  @default(false)
  payload       String   // Raw JSON payload
  error         String?  // Processing error if any
  attempts      Int      @default(0)
  processedAt   DateTime?
  createdAt     DateTime @default(now())

  @@index([provider, processed])
  @@index([eventId])
  @@index([createdAt])
}

// User subscription management (Stripe-powered)
model Subscription {
  id                   String    @id @default(cuid())
  userId               String
  stripeSubscriptionId String    @unique
  stripePriceId        String
  stripeCustomerId     String
  status               String    @default("active") // active, past_due, canceled, unpaid, trialing, paused
  trialStart           DateTime?
  trialEnd             DateTime?
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean   @default(false)
  canceledAt           DateTime?
  gracePeriodEnd       DateTime? // Extra time after payment failure
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([stripeCustomerId])
  @@index([currentPeriodEnd])
}

// Offline actions queue (synced when back online)
model OfflineAction {
  id         String   @id @default(cuid())
  userId     String
  actionType String   // create_task, create_note, create_email_draft, update_task
  entityType String   // task, note, email, time_entry
  entityId   String?  // Local ID (client-generated cuid)
  payload    String   // JSON payload of the action
  status     String   @default("pending") // pending, syncing, completed, failed
  attempts   Int      @default(0)
  error      String?
  createdAt  DateTime @default(now())
  syncedAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([status, createdAt])
}
