# Google OAuth (https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth / Azure AD (https://portal.azure.com/)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=

# NextAuth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=rEsyy+1lTxl7AQR0xx53bFJrJcZy4vJEPiiuOHx1TcI=
NEXTAUTH_URL=http://localhost:3000

# Token Encryption (generate with: openssl rand -base64 32)
ENCRYPTION_KEY=3VekOG+cUvcVsXp7/nv2dXcltwieQRBx2y5jiHQI414=

# Groq AI (get key at https://console.groq.com/)
# If empty, falls back to z-ai-web-dev-sdk
GROQ_API_KEY=

# Stripe (get keys at https://dashboard.stripe.com/)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Public flags for client-side OAuth config detection
NEXT_PUBLIC_GOOGLE_CONFIGURED=false
NEXT_PUBLIC_MICROSOFT_CONFIGURED=false
